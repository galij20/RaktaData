# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# Environment: development | production
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Railway usually provides this as DATABASE_URL automatically when you attach a Postgres service.
# This app also accepts DB_URL for compatibility.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=
DB_URL=

# If your Postgres provider requires TLS, set this to true.
DB_SSL=false

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens
# Use a long random string in production (min 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="12234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234"

# JWT token expiry duration
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the React frontend (used for CORS origin in production)
CLIENT_URL=rakta-data.vercel.app
